{
  "name": "AccessCard",
  "type": "object",
  "properties": {
    "card_number": {
      "type": "string",
      "description": "Unique card number printed on the card (e.g. CEC-00421-A)"
    },
    "linked_employee_id": {
      "type": "string",
      "description": "Employee ID this card belongs to"
    },
    "owner_name": {
      "type": "string",
      "description": "Name of the card holder"
    },
    "clearance_level": {
      "type": "string",
      "enum": [
        "Level 1 - Public",
        "Level 2 - Internal",
        "Level 3 - Confidential",
        "Level 4 - Secret",
        "Level 5 - Top Secret"
      ]
    },
    "department": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "card_number",
    "linked_employee_id",
    "owner_name",
    "clearance_level"
  ]
}
